generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AgencyLead {
  id                  String    @id @default(uuid())
  businessName        String
  niche               String
  location            String?
  contactEmail        String?
  contactPhone        String?
  placeId             String?   @unique
  leadSource          String    @default("COLD") // COLD or INBOUND
  sessionId           String?
  status              String    @default("PROSPECT")
  scoutData           Json?
  intelScore          Int?
  intelData           Json?
  demoSiteUrl         String?
  walkthroughVideoUrl String?
  outreachHistory     Json?
  paymentLink         String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  validUntil          DateTime?
  lastInteraction     DateTime?
}
