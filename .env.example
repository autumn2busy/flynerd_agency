# ─────────────────────────────────────────────────────────────
# FlyNerd Agency — environment variables
# ─────────────────────────────────────────────────────────────
# Copy to `.env` and fill in. `.env` is gitignored.
# Production values live on Vercel (Project Settings → Environment Variables).
# Changes to Vercel env vars require a redeploy to take effect.
# ─────────────────────────────────────────────────────────────

# ─── PostHog — demo page analytics tracking ───────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com


# ─── Sonata-stack integration ─────────────────────────────────
# URL of the Railway-hosted sonata-stack service. No trailing slash.
# Used by /api/apply to dispatch warm-apply (insert AgencyLead row + fire
# Dre). Without this, /api/apply silently skips the Supabase sync and
# warm leads end up as AC orphans — the exact bug that went undiagnosed
# from 4/15–4/22 before we added WARM_APPLY_ORPHAN tagging.
# Example: https://sonata-stack-production.up.railway.app
SONATA_STACK_URL=

# Shared secret for authenticating webhook requests TO sonata-stack.
# MUST match the value of WEBHOOK_SECRET in sonata-stack's Railway env.
# Used by /api/apply and /api/webhooks/cal-booking.
SONATA_WEBHOOK_SECRET=


# ─── ActiveCampaign (CRM) ─────────────────────────────────────
# Base URL without trailing slash, e.g. https://<account>.api-us1.com
ACTIVECAMPAIGN_URL=
ACTIVECAMPAIGN_KEY=

# AC pipeline + initial stage for warm leads submitted via /api/apply.
# Pipeline 4 = "FlyNerd Automation Agency Inbound/Warm" per 2026-04-22.
# The initial stage ID must be looked up in AC (Settings → Pipelines →
# select pipeline → inspect stage URL or use the API). /api/apply skips
# deal creation with a clear log message if the stage ID is missing.
AC_WARM_PIPELINE_ID=4
AC_WARM_INITIAL_STAGE_ID=


# ─── Stripe ───────────────────────────────────────────────────
# Test-mode secret key for catalog bootstrap + invoice helper scripts
STRIPE_TEST_API_KEY=
# Live-mode secret key (keep extremely locked down)
STRIPE_LIVE_API_KEY=
# Optional fallback: scripts prefer the mode-specific keys above but
# fall back to this if set.
STRIPE_API_KEY=
# Optional: base URL Stripe Checkout redirects to on successful payment.
# Defaults to https://flynerd.tech/thanks in bootstrap script.
STRIPE_AFTER_PAYMENT_REDIRECT_BASE=
# Profile 2 (tech-enabled premium) demo page deposit link override.
# Only affects app/demo/[leadId]/page.tsx CTA; catalog pricing pages
# read from services-data.ts directly.
STRIPE_PROFILE2_DEPOSIT_LINK=


# ─── Cal.com ──────────────────────────────────────────────────
# Public booking URL shown to prospects. Shared across /apply step 2
# embed, /thanks booking CTA, Raid invoice memo, and demo page kickoff.
# Example: https://cal.com/flynerdtech/strategy-call
CAL_COM_KICKOFF_LINK=

# Signing secret for Cal.com's webhook delivery (HMAC-SHA256).
# Set on Cal.com's webhook config AND here — they MUST match.
# Used by /api/webhooks/cal-booking to verify inbound events.
CAL_WEBHOOK_SECRET=


# ─── Resend (transactional email) ─────────────────────────────
# Used for the internal /apply qualification notifications sent to
# hello@flynerd.tech.
RESEND_API_KEY=


# ─── Anthropic (Claude SDK) ───────────────────────────────────
# Used by chat-demo route + agent prompts. Sonata-stack has its own
# copy of this key in Railway env.
ANTHROPIC_API_KEY=


# ─── Supabase ─────────────────────────────────────────────────
# Full Postgres connection string for Prisma client
DATABASE_URL=
# Supabase project ref (for direct REST calls if needed)
SUPABASE_PROJECT_REF=
# Service role key for server-side writes — NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=


# ─── External integrations (agents, scraping, deploys) ────────
# Vercel API token for Dre's per-client demo deployments
VERCEL_API_TOKEN=
# Google Places API for Simon's business discovery agent
GOOGLE_PLACES_API_KEY=
# Yelp API for Yoncé's reputation enrichment
YELP_API_KEY=
# HeyGen API for demo video assets (if used)
HEYGEN_API_KEY=
# Groq API for legacy agent endpoints (migrating to Anthropic per
# CLAUDE.md roadmap)
GROQ_API_KEY=


# ─── Site config ──────────────────────────────────────────────
# Set to "true" on the flynerd.tech deployment. Toggles marketing-site-
# only code paths vs client-template behavior.
IS_MAIN_SITE=true
NEXT_PUBLIC_BASE_URL=https://flynerd.tech
