{
  "name": "flynerd-agency",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:n8n": "next dev -p 3010",
    "check:statuses": "node scripts/check-status-literals.mjs",
    "build": "node scripts/check-status-literals.mjs && prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "stripe:bootstrap:dry": "tsx scripts/stripe-catalog-bootstrap.ts --mode=test --dry-run",
    "stripe:bootstrap:test": "tsx scripts/stripe-catalog-bootstrap.ts --mode=test",
    "stripe:bootstrap:live": "tsx scripts/stripe-catalog-bootstrap.ts --mode=live",
    "invoice:raid:dry": "tsx scripts/send-custom-invoice.ts --client=raid --mode=test --dry-run",
    "invoice:raid:test": "tsx scripts/send-custom-invoice.ts --client=raid --mode=test",
    "invoice:raid:live:dry": "tsx scripts/send-custom-invoice.ts --client=raid --mode=live --dry-run",
    "invoice:raid:live": "tsx scripts/send-custom-invoice.ts --client=raid --mode=live"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@prisma/client": "^5.22.0",
    "framer-motion": "^12.30.0",
    "googleapis": "^171.4.0",
    "groq-sdk": "^1.1.1",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "node-activecampaign": "^0.0.9",
    "openai": "^6.27.0",
    "posthog-js": "^1.368.2",
    "posthog-node": "^4.18.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "resend": "^6.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^16.4.7",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^5.22.0",
    "stripe": "^22.0.2",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
