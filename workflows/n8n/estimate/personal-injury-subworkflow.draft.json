        "jsCode": "let input = $input.first().json;\nif (input.input && typeof input.input === 'string') { try { input = JSON.parse(input.input); } catch(e) {} }\nconst errors = [];\nif (!input.session_key) errors.push('session_key required');\nif (!input.issue_type) errors.push('issue_type required');\nreturn { json: { ...input, niche: 'personal_injury', valid: errors.length === 0, errors } };"
